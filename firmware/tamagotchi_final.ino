
// ── PIN DEFINITIONS ─────────────────────────────────────────
#define BTN_LEFT          D0   // SW1 (INPUT_PULLUP → LOW when pressed)
#define BTN_MIDDLE        D1   // SW2
#define BTN_RIGHT         D2   // SW3
#define BUZZER_PIN        D10  // Buzzer OUTPUT
#define RED_LED_PIN       D6   // RGB Red   OUTPUT
#define GREEN_LED_PIN     D7   // RGB Green OUTPUT
#define BLUE_LED_PIN      D8   // RGB Blue  OUTPUT
#define TOUCH_SENSOR_PIN  D9   // Touch sensor INPUT (HIGH when touched)

// ── LIBRARIES ───────────────────────────────────────────────
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// ── DISPLAY ─────────────────────────────────────────────────
#define SCREEN_WIDTH  128
#define SCREEN_HEIGHT  64
#define OLED_RESET     -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// ============================================================
//  PET MODEL
// ============================================================
struct Pet {
  int hunger;        // 0–100  (0 = starving,    100 = full)
  int happiness;     // 0–100  (0 = miserable,   100 = ecstatic)
  int energy;        // 0–100  (0 = exhausted,   100 = fully rested)
  int learning;      // 0–100  (tracks study progress this cycle)
  int petting;       // 0–100  (fades without touch)
  unsigned long age; // seconds alive (increments every 5 s tick)
};
Pet pet;

// ============================================================
//  UI STATE MACHINE
// ============================================================
